# --- Secrets (NEVER commit) ---
.env
.env.*
!.env.example
*.pem

# --- Dependencies ---
node_modules/
.pnp
.pnp.js

# --- Build / packaged output ---
# NOTE: electron-vite compiles to out/ and electron-builder packages to dist/ (and
# release/). `build/` is NOT output here — it holds tracked source icon resources
# (electron-builder buildResources), so it is deliberately not ignored.
dist/
dist-electron/
out/
release/
*.local
.eslintcache

# --- Electron / runtime artifacts ---
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Editor / OS cruft ---
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# --- Claude Code local-only settings ---
.claude/settings.local.json

# --- Test / coverage ---
coverage/
.nyc_output/
